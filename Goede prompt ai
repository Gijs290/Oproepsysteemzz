function mgmtSet(i,key,val){ const p=patiënten[i]; p[key]=val; if(key==="status") ensureWachtStart(patiënten[i]); saveData(); renderManagement(); updateLijst(); updateDokter(); updateStats(); showNotify("Wijziging opgeslagen", `${key} → ${val}`, "#1e90ff"); }
function mgmtSetId(i,newId){
  newId=(newId||"").trim(); if(!newId){ showNotify("ID kan niet leeg", "", "#cf2a2a"); renderManagement(); return; }
  const clash=patiënten.some((p,ix)=> ix!==i && p.id===newId); if(clash){ showNotify("ID bestaat al", newId, "#cf2a2a"); renderManagement(); return; }
  const oldId=patiënten[i].id; patiënten[i].id=newId; recepten.forEach(r=>{ if(r.id===oldId) r.id=newId; });
  if(reportsByPerson[oldId] && !reportsByPerson[newId]){ reportsByPerson[newId]=reportsByPerson[oldId]; delete reportsByPerson[oldId]; }
