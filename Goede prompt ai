      </div>
    </details>`;
  }).join("");

  // Paste detect
  DEPARTMENTS.forEach(dep=>{
    const rb=document.getElementById(`sol_rb_${dep}`);
    const dc=document.getElementById(`sol_dc_${dep}`);
    if(rb) rb.addEventListener('paste', ()=>{ rb.setAttribute('data-pasted','1'); });
    if(dc) dc.addEventListener('paste', ()=>{ dc.setAttribute('data-pasted','1'); });
  });
}
function clearSol(dep){
  const rb=document.getElementById(`sol_rb_${dep}`);
  const dc=document.getElementById(`sol_dc_${dep}`);
  if(rb) rb.value=""; if(dc) dc.value="";
  const qs=DEPT_QUESTIONS[dep]||[];
  qs.forEach((_,qi)=>{ const el=document.getElementById(`sol_q_${dep}_${qi}`); if(el) el.value=""; });
  const msg=document.getElementById(`sol_msg_${dep}`); if(msg) msg.textContent="";
}
function submitSollicitatie(dep){
  const rbEl=document.getElementById(`sol_rb_${dep}`);
  const dcEl=document.getElementById(`sol_dc_${dep}`);
  const qs=DEPT_QUESTIONS[dep]||[];
  const answers={};
  for(let i=0;i<qs.length;i++){
    const v=(document.getElementById(`sol_q_${dep}_${i}`).value||"").trim();
    if(!v){ document.getElementById(`sol_msg_${dep}`).textContent="Beantwoord alle verplichte vragen."; return; }
    answers[qs[i]] = v;
  }
  const roblox=(rbEl.value||"").trim();
  const discord=(dcEl.value||"").trim();
  if(!roblox || !discord){ document.getElementById(`sol_msg_${dep}`).textContent="Roblox en Discord zijn verplicht."; return; }
  const pasted={ roblox: !!rbEl.getAttribute('data-pasted'), discord: !!dcEl.getAttribute('data-pasted') };
  const rec={ afdeling:dep, roblox, discord, answers, pasted, status:"Nieuw", created:now() };
  sollicitaties.push(rec); saveData();
  document.getElementById(`sol_msg_${dep}`).textContent="Sollicitatie ontvangen. Bedankt!";
  rbEl.value=""; dcEl.value="";
  qs.forEach((_,i)=>{ const el=document.getElementById(`sol_q_${dep}_${i}`); if(el) el.value=""; });
  rbEl.removeAttribute('data-pasted'); dcEl.removeAttribute('data-pasted');
}

