Ik stuur een script door die werkt en waar het meeste in zit wat ik wil maar pas nog een paar dingen aan scrijf het wel even zodat ik niks er in hoef te voegen en voeg zelf ook functies toe welke jij mooi/goed vindt. neem je tijd en maakt niet uit als het een lang script is (max rond de 4500 rijen) <!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Ziekenhuis Zevenaar Systeem</title>
<style>
  :root{
    --bg:#eef5fb; --ink:#0a3d62; --ink-2:#1e90ff; --card:#fff;
    --ok:#b8f5b8; --busy:#ffb3b3; --shadow:0 4px 12px rgba(0,0,0,.1);
    --radius:12px; --ink-text:#222; --muted:#666; --pill:#f7fbff; --pill-b:#dde4ea;
    --menu-w:280px; --accent:#1e90ff; --good:#2ecc71; --warn:#ffb84d; --bad:#cf2a2a;
  }
  [data-theme="dark"]{
    --bg:#0f1722; --ink:#0f5fa8; --ink-2:#2f9bff; --card:#121a26;
    --ok:#1f6d1f; --busy:#7b1f1f; --ink-text:#e6e6e6; --muted:#aab3bd; --pill:#0d2235; --pill-b:#1e3a55;
    --shadow:0 6px 14px rgba(0,0,0,.35); --accent:#2f9bff; --good:#2ecc71; --warn:#ffcc66; --bad:#e55;
  }
  *{box-sizing:border-box}
  body{ margin:0; font-family:Arial,system-ui,-apple-system,Segoe UI,Roboto,sans-serif; background:var(--bg); color:var(--ink-text); }

  /* Topbar */
  .topbar{ position:fixed; top:0; left:0; right:0; height:52px; background:var(--card);
    display:flex; align-items:center; justify-content:space-between; padding:0 14px; box-shadow:var(--shadow); z-index:1000; }
  .topbar .left{ display:flex; gap:10px; align-items:center }
  .topbar .right{ display:flex; gap:8px; align-items:center }
  .pill-sm{ padding:6px 10px; background:var(--pill); border:1px solid var(--pill-b); border-radius:999px; font-size:12px; display:inline-flex; gap:6px; align-items:center; cursor:pointer }

  /* Drukte indicator chip */
  #busyChip{ font-weight:700; }
  .busy-rustig{ background:#e9fff0; color:#146b2e; border-color:#c2efcf; }
  .busy-normaal{ background:#eef6ff; color:#0a3d62; border-color:#cfe3ff; }
  .busy-druk{ background:#fff4e0; color:#6a5400; border-color:#ffdd9f; }
  .busy-extreem{ background:#ffeaea; color:#8b1111; border-color:#ffb3b3; }

  /* Zijmenu */
  .menu{
    width:var(--menu-w); height:calc(100vh - 52px); background:var(--ink); color:#fff;
    position:fixed; top:52px; left:0; padding:20px; overflow:auto;
    transition: transform .25s ease, opacity .25s ease;
  }
  .menu h2{ text-align:center; margin:10px 0 16px }
  .menu button{ width:100%; padding:12px 14px; margin-top:10px; background:linear-gradient(135deg,#1f77ff,#00a2ff);
    border:none; color:#fff; font-weight:800; cursor:pointer; border-radius:10px; display:flex; align-items:center; gap:10px; box-shadow:0 6px 14px rgba(0,0,0,.15); }
  .menu button:hover{ filter:brightness(1.06) }
  [data-theme="dark"] .menu button:hover{ filter:brightness(1.1) }
  .menu .icon{ width:22px; text-align:center; flex:0 0 22px }

  /* Menu verbergen */
  body.menu-hidden .menu{ transform: translateX(-110%); opacity: 0; pointer-events:none; }

  /* Content */
  .content{ margin-left:calc(var(--menu-w) + 20px); padding:72px 28px 28px; max-width:1280px; transition: margin-left .25s ease; }
  body.menu-hidden .content{ margin-left:20px; }

  /* Cards/inputs */
  .card{ background:var(--card); padding:20px; margin:15px 0; border-radius:var(--radius); box-shadow:var(--shadow); }
  .row{ display:flex; flex-wrap:wrap; gap:10px; align-items:center }
  .col{ flex:1 1 240px }
  input, select, textarea{ width:100%; padding:10px; border-radius:8px; border:1px solid #cfd6dd; background:#fff; }
  [data-theme="dark"] input, [data-theme="dark"] select, [data-theme="dark"] textarea{ background:#0b1320; color:var(--ink-text); border-color:#223246; }
  textarea{ min-height:70px; resize:vertical }
  label{ display:block; font-size:13px; color:#333; margin:8px 0 4px }
  [data-theme="dark"] label{ color:#c7d1dc }
  .actions{ display:flex; gap:8px; flex-wrap:wrap; margin-top:10px }
  button.action{ padding:10px 14px; background:var(--ink); color:#fff; border:none; border-radius:9px; cursor:pointer; font-weight:800; }
  button.action:hover{ background:var(--ink-2) }
  .danger{ background:var(--bad) !important } .danger:hover{ filter:brightness(1.08) }
  .stat{ font-size:28px; font-weight:800 }
  .list-empty{ color:var(--muted); font-style:italic }
  .pill{ display:inline-flex; align-items:center; gap:6px; padding:6px 10px; border-radius:999px; border:1px solid #cfd6dd; background:#f7fbff; font-size:12px }

  /* Status tags */
  .tag{ display:inline-block; padding:4px 8px; border-radius:999px; font-size:12px; font-weight:700 }
  .tag.wait{ background:#e6f2ff; color:#0a3d62; border:1px solid #b6d6ff }
  .tag.pickup{ background:#e3f7e3; color:#0b5c0b; border:1px solid #bce8bc }
  .tag.busy{ background:#fff1b6; color:#6a5400; border:1px solid #ffdd66 }
  .tag.done{ background:#e4ffe4; color:#155d15; border:1px solid #b2f0b2 }

  /* Rol badges */
  .role-badge{ border-radius:999px; padding:4px 10px; font-weight:700; color:#fff; display:inline-block; font-size:12px }
  .r-balie{ background:#2b7cff } .r-balie.hoofd-tint{ background:#1e63d6 }
  .r-verpleegkundige{ background:#00b894 } .r-verpleegkundige.hoofd-tint{ background:#00a383 }
  .r-chirurg{ background:#e17055 } .r-chirurg.hoofd-tint{ background:#c95a3f }
  .r-arts{ background:#6c5ce7 } .r-arts.hoofd-tint{ background:#5849d2 }
  .r-dokter{ background:#fdcb6e; color:#333 } .r-dokter.hoofd-tint{ background:#f4b544; color:#333 }
  .r-apotheek{ background:#00cec9 } .r-apotheek.hoofd-tint{ background:#00b3ae }
  .r-management{ background:#1e90ff }

  /* Topbar naam + status */
  #userNameBadge{ display:none; }
  #topStatus{ display:none; align-items:center; gap:6px; }
  #topStatus .status-select{ padding:4px 6px; border-radius:8px; border:1px solid #cfd6dd; background:#fff; font-size:12px; }
  #topStatus .note-btn{ padding:4px 8px; border-radius:8px; border:1px solid #cfd6dd; background:#f7fbff; cursor:pointer; font-size:12px; }
  [data-theme="dark"] #topStatus .status-select{ background:#0b1320; color:var(--ink-text); border-color:#223246; }
  [data-theme="dark"] #topStatus .note-btn{ background:#0d2235; border-color:#1e3a55; }

  /* Overlays */
  #loginOverlay{ position:fixed; inset:0; display:none; align-items:center; justify-content:center; background:rgba(0,0,0,.6); z-index:100000; }
  #loginBox{ width:min(92vw, 380px); background:#fff; padding:24px; border-radius:12px; box-shadow:0 12px 40px rgba(0,0,0,.35); }

  #notifyUI{ position:fixed; inset:0; display:none; align-items:center; justify-content:center; background:rgba(0,0,0,.35); z-index:9999; }
  .noteBox{ background:#fff; padding:26px 30px; border-radius:16px; text-align:center; min-width:min(92vw,540px); box-shadow:0 20px 60px rgba(0,0,0,.35); border-top:10px solid var(--note-accent,#1e90ff); }
  .noteTitle{ font-size:32px; font-weight:800; color:#0a3d62; margin:0 }
  .noteSub{ margin-top:8px; font-size:16px; color:#333 }

  #oproepUI{ position:fixed; inset:0; display:none; align-items:center; justify-content:center; background:rgba(0,0,0,.6); z-index:9998 }
  .oproepBox{ background:#fff; padding:50px; border-radius:20px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,.35) }
  .oproepNaam{ font-size:56px; font-weight:800; color:var(--ink) }
  .oproepTekst{ font-size:26px; margin-top:10px }

  /* Accordion */
  details.section{ border:1px solid #dbe4ee; border-radius:12px; background:#f7fbff; margin:14px 0; }
  details.section summary{ list-style:none; cursor:pointer; padding:12px 16px; font-weight:800; display:flex; gap:10px; align-items:center; }
  details.section[open] summary{ border-bottom:1px solid #dbe4ee; }
  .count-badge{ background:#0a3d62; color:#fff; border-radius:999px; padding:3px 8px; font-size:12px }
  .row-compact{ display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin:6px 0 }

  /* Triage chips */
  .tri-red{ background:#ffe6e6; color:#b30000; border:1px solid #ffb3b3 }
  .tri-orange{ background:#fff1df; color:#7a4200; border:1px solid #ffd7a8 }
  .tri-yellow{ background:#fffce0; color:#6b6500; border:1px solid #fff6a0 }
  .tri-green{ background:#e7ffe7; color:#165c16; border:1px solid #bbf0bb }
  .tri-blue{ background:#e6f1ff; color:#0c488b; border:1px solid #bfd8ff }

  /* Rooms */
  .room{ display:inline-block; margin:6px 6px 0 0; padding:6px 10px; border-radius:8px; border:1px solid #cfd6dd; cursor:pointer; user-select:none; }
  .room.occupied{ background:#ffeaea; color:#8b1111; border-color:#ffb3b3 }
  .room.available{ background:#eaffea; color:#166b16; border-color:#c7f1c7 }
  .room:hover{ filter:brightness(0.98) }

  /* Charts */
  .chartBox{ background:var(--card); border-radius:12px; box-shadow:var(--shadow); padding:12px; }

  /* Template overlay for copyable messages */
  #templateOverlay{ position:fixed; inset:0; display:none; align-items:center; justify-content:center; background:rgba(0,0,0,.55); z-index:100001; }
  #templateBox{ max-width:min(92vw,820px); max-height:80vh; overflow:auto; background:#fff; border-radius:14px; padding:18px 20px; box-shadow:0 20px 60px rgba(0,0,0,.45); }
  .code{ font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size:12px }
</style>
</head>
<body>

<!-- Topbar -->
<div class="topbar">
  <div class="left">
    <button class="pill-sm" id="menuToggle" title="Menu verbergen/tonen">☰ Menu</button>
    <span class="pill-sm"><strong>Ziekenhuis</strong> Zevenaar</span>

    <!-- Drukte indicator -->
    <span class="pill-sm busy-normaal" id="busyChip" title="Klik om drukte aan te passen">📈 Drukte: Normaal</span>

    <span class="pill-sm" id="roleBadge">Rol: —</span>
    <span class="pill-sm" id="userNameBadge">—</span>
    <span id="topStatus">
      <select id="topStatusSelect" class="status-select"></select>
      <button id="topStatusNoteBtn" class="note-btn" title="Notitie aanpassen">📝 Notitie</button>
    </span>
  </div>
  <div class="right">
    <button class="pill-sm" id="darkToggle" title="Schakel donker/licht">🌙 Donker</button>
    <button class="pill-sm" onclick="showLogin()">🔑 Login</button>
    <button class="pill-sm" onclick="logout()">🚪 Logout</button>
  </div>
</div>

<!-- Overlays -->
<div id="loginOverlay" role="dialog" aria-modal="true">
  <div id="loginBox">
    <h2 style="margin-top:0">Inloggen</h2>
    <p style="color:#444">Log in met je <strong>roepnummer</strong> en <strong>wachtwoord</strong>.</p>
    <label>Roepnummer (ZZ-01 t/m ZZ-99)</label>
    <input id="login_roepnummer" placeholder="Bijv. ZZ-16" autocomplete="off"/>
    <label style="margin-top:10px; display:block">Wachtwoord</label>
    <input id="login_wachtwoord" type="password" placeholder="Wachtwoord" autocomplete="current-password"/>
    <div style="margin-top:12px; color:#a33" id="login_error"></div>
    <div style="display:flex; gap:8px; margin-top:16px">
      <button id="login_btn" style="flex:1; padding:10px; border:none; border-radius:8px; background:#0a3d62; color:#fff; cursor:pointer">Inloggen</button>
      <button onclick="resetLogin()" style="padding:10px; border:none; border-radius:8px; background:#888; color:#fff; cursor:pointer">Wissen</button>
    </div>
  </div>
</div>
<div id="notifyUI"></div>
<div id="oproepUI"></div>

<!-- Tijdlijn overlay -->
<div id="timelineOverlay">
  <div id="timelineBox"></div>
</div>

<!-- Template message overlay -->
<div id="templateOverlay">
  <div id="templateBox"></div>
</div>

<!-- Zijmenu -->
<div class="menu">
  <h2>Menu</h2>
  <!-- Publiek -->
  <button onclick="showPage('afspraken')"><span class="icon">📅</span><span class="label">Afspraken (publiek)</span></button>
  <button onclick="showPage('afdelingen')"><span class="icon">🏥</span><span class="label">Afdelingen & Sollicitaties</span></button>
  <button onclick="showPage('nakijken')"><span class="icon">🔎</span><span class="label">Nakijken (sollicitaties)</span></button>

  <!-- Intern -->
  <button onclick="showPage('database')"><span class="icon">📋</span><span class="label">Patiënten Database</span></button>
  <button onclick="showPage('oproep')"><span class="icon">🔔</span><span class="label">Oproepsysteem</span></button>
  <button onclick="showPage('dokter')"><span class="icon">🩺</span><span class="label">Doktersportaal</span></button>
  <button onclick="showPage('dokters')"><span class="icon">👨‍⚕️</span><span class="label">Dokters (beschikbaarheid)</span></button>
  <button onclick="showPage('apotheek')"><span class="icon">💊</span><span class="label">Apotheek</span></button>
  <button onclick="showPage('kamers')"><span class="icon">🚪</span><span class="label">Kamerbeheer</span></button>
  <button onclick="showPage('coord')"><span class="icon">🧭</span><span class="label">Teamcoördinatie</span></button>
  <button onclick="showPage('management')"><span class="icon">🛠️</span><span class="label">Management</span></button>
</div>

<!-- Content -->
<div class="content">

  <!-- AFSPRAKEN (PUBLIEK) -->
  <section id="afspraken" style="display:none">
    <h2>Maak een afspraak</h2>
    <div class="card">
      <p class="pill">Dit formulier is voor <strong>bezoekers/patiënten</strong>. Medewerkers kunnen rechtsboven <strong>inloggen</strong>.</p>
      <div class="row">
        <div class="col"><label>Roblox user* (zichtbaar in nakijken)</label><input id="ap_roblox" placeholder="Bijv. Itz_gz29" /></div>
        <div class="col"><label>Discord user* (naam#0000 of @naam)</label><input id="ap_discord" placeholder="@voorbeeld of naam#1234" /></div>
        <div class="col"><label>Voorkeursdatum & tijd</label><input id="ap_dt" type="datetime-local" /></div>
      </div>

      <label>Reden van afspraak*</label>
      <textarea id="ap_reden" placeholder="Beschrijf kort uw klacht/reden..."></textarea>

      <div class="row">
        <div class="col">
          <label>Afdeling (keuze/suggestie)</label>
          <select id="ap_afdeling">
            <option value="">(kies of gebruik suggestie)</option>
            <option>SEH</option><option>Huisartsenpost</option><option>Chirurgie</option>
            <option>Cardiologie</option><option>Longgeneeskunde</option><option>Neurologie</option>
            <option>Apotheek</option><option>Administratie</option>
          </select>
        </div>
        <div class="col">
          <label>Slimme suggestie (op basis van reden)</label>
          <input id="ap_suggest" disabled />
        </div>
        <div class="col">
          <label>Patiënt-ID (optioneel)</label>
          <input id="ap_pid" placeholder="Bijv. 2026-0001" />
        </div>
      </div>

      <div class="actions">
        <button class="action" onclick="detectAfdeling()">🔎 Bepaal afdeling</button>
        <button class="action" onclick="afspraakOpslaan()">✅ Afspraak aanvragen</button>
        <button class="action" onclick="afspraakLeeg()">Wissen</button>
      </div>
      <div id="ap_msg" class="list-empty" style="margin-top:6px"></div>
    </div>

    <div class="card">
      <h3>Openstaande afspraken (wachten op verwerking)</h3>
      <div id="ap_open"></div>
    </div>
  </section>

  <!-- AFDELINGEN & SOLLICITATIES -->
  <section id="afdelingen" style="display:none">
    <h2>Afdelingen & Sollicitaties</h2>
    <div id="afdelingenLijst"></div>
  </section>

  <!-- NAKIJKEN SOLLICITATIES -->
  <section id="nakijken" style="display:none">
    <h2>Nakijken – Sollicitaties</h2>
    <div class="card">
      <div class="row">
        <div class="col"><input id="chk_search" placeholder="Zoek op Roblox, Discord of afdeling..." /></div>
        <div class="col">
          <select id="chk_filter">
            <option value="">Alle statussen</option>
            <option>Nieuw</option><option>Goedgekeurd</option><option>Afgewezen</option>
          </select>
        </div>
        <div class="col">
          <button class="action" onclick="renderNakijken()">Zoek</button>
          <button class="action" onclick="document.getElementById('chk_search').value=''; document.getElementById('chk_filter').value=''; renderNakijken()">Reset</button>
        </div>
      </div>
    </div>
    <div id="nakijkenList"></div>
  </section>

  <!-- DATABASE -->
  <section id="database" style="display:none">
    <h2>Patiënten Database</h2>

    <div class="card">
      <h3>Nieuwe patiënt toevoegen</h3>
      <div class="row">
        <div class="col"><label>Naam*</label><input id="f_naam" placeholder="Bijv. Jan Jansen" /></div>
        <div class="col"><label>ID* (uniek)</label><input id="f_id" placeholder="Bijv. 2026-0001" /></div>
        <div class="col"><label>Medisch rapport</label>
          <select id="f_rapport"><option>Ja</option><option>Nee</option></select>
        </div>
        <div class="col"><label>Allergieën (komma‑gescheiden)</label>
          <input id="f_allerg" placeholder="Bijv. Penicilline, Noten" />
        </div>
        <div class="col">
          <label>SEH Triage (NTS)</label>
          <select id="f_triage">
            <option>Groen</option><option>Geel</option><option>Oranje</option><option>Rood</option><option>Blauw</option>
          </select>
        </div>
      </div>

      <!-- Kamerkeuze + bezetlijst -->
      <div class="row">
        <div class="col">
          <label>Kamer (optioneel)</label>
          <select id="f_room"></select>
        </div>
        <div class="col">
          <label>Niet beschikbaar</label>
          <div id="rooms_unavailable" class="row-compact"></div>
        </div>
      </div>

      <label>Reden van afspraak</label>
      <textarea id="f_reden" placeholder="Klacht of reden voor komst..."></textarea>

      <div class="actions">
        <button class="action" onclick="registreer()">Registreren</button>
        <button class="action" onclick="clearForm()">Velden leegmaken</button>
        <button class="action" onclick="seedDemo()">Vul demo‑data</button>
      </div>
      <div id="valMsg" class="list-empty" style="margin-top:6px"></div>
    </div>

    <div class="card">
      <div class="row">
        <div class="col"><input id="zoek" placeholder="Zoek op naam, ID of reden..." /></div>
        <div class="col">
          <select id="filter_status">
            <option value="">Alle statussen</option>
            <option>Wachtkamer</option><option>Wordt opgehaald</option><option>Bezig</option><option>Afgehandeld</option>
          </select>
        </div>
        <div class="col">
          <select id="filter_triage">
            <option value="">Alle triage</option>
            <option>Rood</option><option>Oranje</option><option>Geel</option><option>Groen</option><option>Blauw</option>
          </select>
        </div>
        <div class="col">
          <button class="action" onclick="zoekPatient()">Zoek</button>
          <button class="action" onclick="resetZoek()">Reset filters</button>
        </div>
      </div>
    </div>

    <div id="patientLijst"></div>
  </section>

  <!-- OPROEPSYSTEEM -->
  <section id="oproep" style="display:none">
    <h2>Oproepsysteem</h2>
    <div class="row">
      <div class="card stat">Wachtenden: <span id="aantal">0</span></div>
      <div class="card stat">Laatst opgeroepen: <span id="laatste">-</span></div>
      <div class="card stat">Gem. wachttijd: <span id="wachttijd">0</span> sec</div>
    </div>
    <div class="card">
      <p class="pill">Flow: <strong>Volgende</strong> → <strong>Wordt opgehaald</strong> → dokter <em>claimt</em> → <strong>Bezig</strong>. Voorang op <strong>SEH Triage</strong>: Rood → Oranje → Geel → Groen → Blauw, daarna wachttijd.</p>
      <div class="actions" style="margin-top:12px">
        <button class="action" style="font-size:18px;padding:14px 18px" onclick="volgende()">Volgende patiënt oproepen</button>
        <button class="action" onclick="toonWachtlijst()">Toon huidige wachtlijst</button>
        <button class="action" onclick="toggleAutoCall()"><span id="autoCallTxt">Auto‑oproep: Uit</span></button>
        <button class="action danger" onclick="resetAvgWait()">Reset wachttijd‑meting</button>
      </div>
      <div id="wachtlijst"></div>
    </div>
  </section>

  <!-- DOKTERSPORTAAL -->
  <section id="dokter" style="display:none">
    <h2>Doktersportaal</h2>
    <div class="card">
      <div class="row">
        <div class="col"><span class="pill">Ingelogd: <strong id="dokNaam">—</strong></span></div>
        <div class="col">
          <select id="dokFilter" onchange="updateDokter()">
            <option value="alle">Toon: Alle (actieve) patiënten</option>
            <option value="mijn">Toon: Alleen aan mij toegewezen</option>
          </select>
        </div>
      </div>
      <p style="margin-top:6px">
        <em>Haal op (claim)</em> → <strong>Bezig</strong>. Voor <em>Afgehandeld</em> is <strong>behandeling</strong> verplicht.
        Recepten: (hoofd)Dokter/Arts/Chirurg & Management. Let op <strong>allergieën</strong>.
      </p>
    </div>
    <div id="dokterLijst"></div>
  </section>

  <!-- DOKTERS (BESCHIKBAARHEID) -->
  <section id="dokters" style="display:none">
    <h2>Dokters – Beschikbaarheid</h2>
    <div id="myDocCard" class="card" style="display:none">
      <h3>Mijn beschikbaarheid</h3>
      <div class="row">
