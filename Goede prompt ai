function renderAfdelingen(){
  const host=document.getElementById("afdelingenLijst"); if(!host) return;
  host.innerHTML = DEPARTMENTS.map(dep=>{
    const qs=DEPT_QUESTIONS[dep]||[];
    const qaHtml = qs.map((q,qi)=>`
      <label>${esc(q)}*</label>
      <textarea id="sol_q_${dep}_${qi}" placeholder="Antwoord..."></textarea>
    `).join("");
    return `
    <details class="card">
      <summary class="row-compact"><strong>${dep}</strong> <span class="pill">Sollicitatie</span></summary>
      <div style="margin-top:10px">
        <div class="row">
          <div class="col"><label>Roblox user*</label><input id="sol_rb_${dep}"/></div>
