  if(msg.length){ document.getElementById("valMsg").textContent="• "+msg.join(" • "); return; }
  document.getElementById("valMsg").textContent="";

  const p={ naam,id,medischRapport:(rapport==="Ja"),reden,status,behandeling:"",dokter:"",aangemaakt:now(),wachtStart:now(), allergieën:allerg, triage, kamer:prefRoom||"" };
  patiënten.push(p); saveData();
  logAction(currentUser.roepnummer||"—","Patiënt geregistreerd",`${naam} (${id})`);
