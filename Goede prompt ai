function validate(naam,id){
  let msg=[];
  if(!naam||naam.length<2) msg.push("Naam is verplicht (minimaal 2 tekens).");
  if(!id) msg.push("ID is verplicht.");
  const re=/^[A-Za-z0-9\-\_\.]{2,}$/;
  if(id && !re.test(id)) msg.push("ID mag letters/cijfers/-/_/. bevatten.");
  if(patiënten.some(p=>p.id===id)) msg.push("Er bestaat al een patiënt met dit ID.");
  return msg;
}
