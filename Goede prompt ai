  const naam=document.getElementById("f_naam").value.trim();
  const id=document.getElementById("f_id").value.trim();
  const rapport=document.getElementById("f_rapport").value;
  const status="Wachtkamer"; // default bij registratie
  const reden=document.getElementById("f_reden").value.trim();
  const allerg=(document.getElementById("f_allerg").value||"").split(",").map(x=>x.trim()).filter(Boolean);
  const triage=document.getElementById("f_triage").value;
  const prefRoom=(document.getElementById("f_room").value||"").trim();

