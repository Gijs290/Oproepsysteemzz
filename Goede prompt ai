})();

/* ===========================
   DRUKTE INDICATOR
=========================== */
const BUSY_KEY="zzh_busy_level";
const busyChip=document.getElementById("busyChip");
function busyLabelToClass(lbl){
  const v=(lbl||"").toLowerCase();
  if(v.includes("extreem")) return "busy-extreem";
  if(v.includes("druk")) return "busy-druk";
  if(v.includes("rustig")) return "busy-rustig";
  return "busy-normaal";
}
function setBusyLabel(lbl){
  busyChip.textContent="📈 Drukte: "+lbl;
  busyChip.className="pill-sm "+busyLabelToClass(lbl);
  localStorage.setItem(BUSY_KEY,lbl);
}
(function initBusy(){ const v=localStorage.getItem(BUSY_KEY)||"Normaal"; setBusyLabel(v); })();
busyChip.onclick=()=>{
  const cur=localStorage.getItem(BUSY_KEY)||"Normaal";
  const opts=["Rustig","Normaal","Druk","Extreem"];
  const next=prompt("Drukte instellen: (Rustig/Normaal/Druk/Extreem)", cur) || cur;
  if(opts.includes(next)) setBusyLabel(next);
};

/* ===========================
   LOGIN / ROLLEN
=========================== */
const PASSWORD_GENERAL = "ZZ3194";
const PASSWORD_DOCTOR  = "ZZdokter9254";
const PASSWORD_MGMT    = "ZZmanagement67249";
const RESERVED_MGMT_ROEP = "ZZ-01";
const ENFORCE_RESERVED_MGMT = true;

const ALL_ROLES = [
  "Balie","Verpleegkundige","Chirurg","Arts","Dokter","Apotheek",
  "Hoofd Balie","Hoofd Verpleegkundige","Hoofd Chirurg","Hoofd Arts","Hoofd Dokter","Hoofd Apotheek",
  "Management"
];
function roleBaseKey(role){ const r=(role||"").toLowerCase(); if(r.includes("balie")) return "balie"; if(r.includes("verpleeg")) return "verpleegkundige"; if(r.includes("chirurg")) return "chirurg"; if(r.includes("arts")) return "arts"; if(r.includes("dokter")) return "dokter"; if(r.includes("apotheek")) return "apotheek"; if(r==="management") return "management"; return "balie"; }
function roleClass(role){
  const base=roleBaseKey(role); const isHoofd=(role||"").toLowerCase().startsWith("hoofd");
  return `role-badge r-${base}${isHoofd?' hoofd-tint':''}`;
}
function roleAccentHex(role){
  const base=roleBaseKey(role);
  const map={ balie:"#2b7cff", verpleegkundige:"#00b894", chirurg:"#e17055", arts:"#6c5ce7", dokter:"#fdcb6e", apotheek:"#00cec9", management:"#1e90ff" };
  const dark={ balie:"#1e63d6", verpleegkundige:"#00a383", chirurg:"#c95a3f", arts:"#5849d2", dokter:"#f4b544", apotheek:"#00b3ae", management:"#1e90ff" };
  const isHoofd=(role||"").toLowerCase().startsWith("hoofd");
  return isHoofd ? (dark[base]||"#1e90ff") : (map[base]||"#1e90ff");
}
function isDoctorLike(role){
  const r=(role||"").toLowerCase();
  return ["chirurg","arts","dokter"].some(k=> r===k || r.endsWith(" "+k)) || r==="management";
}
function canPrescribe(role){
  const r=(role||"").toLowerCase();
  return r==="management" || r.includes("chirurg") || r.includes("arts") || r.includes("hoofd dokter") || r==="dokter";
}

let rolesByRoep = JSON.parse(localStorage.getItem("zz_roles_v2") || "{}");
let namesByRoep = JSON.parse(localStorage.getItem("zz_names_v1") || "{}");
let eveningRoles = JSON.parse(localStorage.getItem("zz_evening_roles_v1") || "{}");
let activeUsers  = JSON.parse(localStorage.getItem("zz_active_users_v1") || "{}");

/* voorbeelden */
if(!rolesByRoep["ZZ-02"]) rolesByRoep["ZZ-02"]="Balie";
if(!rolesByRoep["ZZ-03"]) rolesByRoep["ZZ-03"]="Verpleegkundige";
if(!rolesByRoep["ZZ-04"]) rolesByRoep["ZZ-04"]="Chirurg";
if(!rolesByRoep["ZZ-05"]) rolesByRoep["ZZ-05"]="Apotheek";
localStorage.setItem("zz_roles_v2", JSON.stringify(rolesByRoep));

let currentUser = { roepnummer: sessionStorage.getItem("user_roep") || "", role: sessionStorage.getItem("user_role") || "" };
function displayName(rn){ const nm=namesByRoep[rn]; return nm? `${nm} (${rn})` : rn; }
function setRoleBadgeText(role, rn){ const el=document.getElementById("roleBadge"); el.className=roleClass(role); el.textContent = `Rol: ${role} — ${displayName(rn)}`; }
function updateTopUserBadge(){
  const el=document.getElementById("userNameBadge");
  if(currentUser.roepnummer){ el.style.display="inline-block"; el.textContent=displayName(currentUser.roepnummer); }
  else{ el.style.display="none"; el.textContent="—"; }
}

/* Active users heartbeat */
setInterval(()=>{
  if(!currentUser.roepnummer) return;
  const rn=currentUser.roepnummer;
  activeUsers[rn]=activeUsers[rn]||{};
  activeUsers[rn].role=currentUser.role;
  activeUsers[rn].name=namesByRoep[rn]||"";
  activeUsers[rn].lastSeen=Date.now();
  localStorage.setItem("zz_active_users_v1", JSON.stringify(activeUsers));
}, 60000);

/* Notify */
function esc(s){ return String(s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }
function showNotify(title, sub="", accent){
  const ui=document.getElementById("notifyUI");
  ui.innerHTML = `<div class="noteBox" style="${accent?`--note-accent:${accent}`:''}">
    <div class="noteTitle">${esc(title)}</div>
    ${sub?`<div class="noteSub">${esc(sub)}</div>`:""}
  </div>`;
  ui.style.display="flex";
  setTimeout(()=>{ ui.style.display="none"; }, 2200);
}

/* Login overlay */
function showLogin(){
  document.getElementById("login_error").textContent = "";
  document.getElementById("login_roepnummer").value = currentUser.roepnummer || "";
  document.getElementById("login_wachtwoord").value = "";
  document.getElementById("loginOverlay").style.display = "flex";
  setTimeout(()=> document.getElementById("login_roepnummer").focus(), 0);
}
function hideLogin(){ document.getElementById("loginOverlay").style.display = "none"; }
function resetLogin(){ document.getElementById("login_roepnummer").value=""; document.getElementById("login_wachtwoord").value=""; document.getElementById("login_error").textContent=""; }
document.getElementById("login_btn").onclick = attemptLogin;
["login_roepnummer","login_wachtwoord"].forEach(id=>{
  const el=document.getElementById(id);
  el.addEventListener("keydown", (e)=>{ if(e.key==="Enter"){ attemptLogin(); }});
});
function attemptLogin(){
  const rn=(document.getElementById("login_roepnummer").value||"").toUpperCase().trim();
  const pw=(document.getElementById("login_wachtwoord").value||"");
  if(!/^ZZ\-(0[1-9]|[1-9][0-9])$/.test(rn)){ document.getElementById("login_error").textContent="Roepnummer ongeldig. Gebruik bijvoorbeeld ZZ-01 of ZZ-16."; return; }
  if(ENFORCE_RESERVED_MGMT && rn===RESERVED_MGMT_ROEP && pw!==PASSWORD_MGMT){ document.getElementById("login_error").textContent="Dit roepnummer vereist het management‑wachtwoord."; return; }
  let sessieRol=null;
  if(pw===PASSWORD_MGMT){ sessieRol="Management"; }
  else if(pw===PASSWORD_DOCTOR){ sessieRol="Chirurg"; }
  else if(pw===PASSWORD_GENERAL){ sessieRol = eveningRoles.map?.[rn] || rolesByRoep[rn] || "Balie"; }
  else { document.getElementById("login_error").textContent="Wachtwoord onjuist."; return; }

  currentUser={ roepnummer: rn, role: sessieRol };
  sessionStorage.setItem("user_roep", rn); sessionStorage.setItem("user_role", sessieRol);
  setRoleBadgeText(sessieRol, rn);
  updateTopUserBadge(); updateTopStatusUI(); hideLogin();

  activeUsers[rn]=activeUsers[rn]||{}; activeUsers[rn].role=sessieRol; activeUsers[rn].name=namesByRoep[rn]||""; activeUsers[rn].lastSeen=Date.now();
  localStorage.setItem("zz_active_users_v1", JSON.stringify(activeUsers));

  showNotify("Ingelogd", `${displayName(rn)} als ${sessieRol}`, roleAccentHex(sessieRol));

  if(isDoctorLike(sessieRol)){ ensureDoctorRecord(rn); saveDoctorAvailability(); }
  routeByRole();
}
function logout(){
  const rn=currentUser.roepnummer;
  sessionStorage.removeItem("user_roep"); sessionStorage.removeItem("user_role");
  currentUser={ roepnummer:"", role:"" };
  const el=document.getElementById("roleBadge"); el.className="pill-sm"; el.textContent="Rol: —";
  updateTopUserBadge(); updateTopStatusUI();
  showNotify("Uitgelogd", rn||"", "#999");
}

/* Access & routing */
const ROLE_ACCESS = {
  afspraken:  ALL_ROLES.concat(["(public)"]),
  afdelingen: ALL_ROLES.concat(["(public)"]),
  nakijken:   ALL_ROLES,
  database:   ALL_ROLES,
  oproep:     ["Balie","Verpleegkundige","Hoofd Balie","Hoofd Verpleegkundige","Management"],
  dokter:     ALL_ROLES.filter(r=> isDoctorLike(r) || r.startsWith("Hoofd ")).concat(["Management"]),
  dokters:    ALL_ROLES,
  apotheek:   ["Apotheek","Hoofd Apotheek","Balie","Verpleegkundige","Management"],
  kamers:     ["Verpleegkundige","Chirurg","Arts","Dokter","Hoofd Verpleegkundige","Hoofd Chirurg","Hoofd Arts","Hoofd Dokter","Management"],
  coord:      ["Hoofd Balie","Hoofd Verpleegkundige","Hoofd Chirurg","Hoofd Arts","Hoofd Dokter","Hoofd Apotheek","Management"],
  management: ["Management"]
};
function ensureAllowedPage(){
  const r=currentUser.role;
  if(!r){ return rawShowPage("afspraken"); }
  if(r==="Management") return rawShowPage("management");
  if(isDoctorLike(r))  return rawShowPage("dokter");
  if(r==="Apotheek"||r==="Hoofd Apotheek") return rawShowPage("apotheek");
  if(r==="Verpleegkundige"||r==="Hoofd Verpleegkundige") return rawShowPage("oproep");
  if(r==="Balie"||r==="Hoofd Balie") return rawShowPage("database");
  return rawShowPage("database");
}
function routeByRole(){ ensureAllowedPage(); }
function showPage(p){
  const allowed=ROLE_ACCESS[p]||[];
  if(allowed.includes("(public)")){ rawShowPage(p); return; }
  if(!currentUser.roepnummer){ showLogin(); return; }
  if(allowed.length && !allowed.includes(currentUser.role)){ showNotify("Geen toegang", `"${p}" voor ${currentUser.role}`, "#cf2a2a"); return ensureAllowedPage(); }
  rawShowPage(p);
}
function rawShowPage(p){
  ["afspraken","afdelingen","nakijken","database","oproep","dokter","dokters","apotheek","kamers","coord","management"].forEach(id=>{
    const el=document.getElementById(id); if(el) el.style.display = (id===p)?"block":"none";
  });
  if(p==="afspraken"){ renderAfsprakenOpen(); }
  if(p==="afdelingen"){ renderAfdelingen(); }
  if(p==="nakijken"){ renderNakijken(); }
  if(p==="database"){ populateRoomsSelect(); updateLijst(); }
  if(p==="oproep"){ updateStats(); renderWachtlijst(); }
  if(p==="dokter"){ document.getElementById("dokNaam").textContent=displayName(currentUser.roepnummer); updateDokter(); }
  if(p==="dokters"){ renderDoctors(); }
  if(p==="apotheek"){ toonRecepten(); renderCollected(); }
  if(p==="kamers"){ renderKamers(); }
  if(p==="coord"){ renderCoord(); renderCoordTeamStatus(); }
  if(p==="management"){ renderManagement(); }
}

/* ===========================
   DATA & OPSLAG
=========================== */
let patiënten=[]; let recepten=[]; let wachttijden=[]; let laatsteKlik=null; let laatsteNaam="-"; let auditLog=[];
let doctorAvailability = {}; // { rn:{status,note,last} }
let personRooms = {};        // { rn:"Kamer/pleknaam" }
let afspraken=[];            // [{roblox,discord,reden,afdeling,dt,patientId,status,note,created}]
let sollicitaties=[];        // [{afdeling,roblox,discord,answers:{q:..}, pasted:{roblox,discord}, status, created}]
let reportsByPerson={};      // { personKey:[{ts,type,details}] }

const STORAGE_KEY = "zzh_data_full_v13";
function saveData(){
  const payload={ patiënten, recepten, wachttijden, laatsteKlik, laatsteNaam, rooms:{rooms1, rooms2}, auditLog, doctorAvailability, personRooms, afspraken, sollicitaties, reportsByPerson, rolesByRoep, namesByRoep, activeUsers, eveningRoles };
  localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
}
function loadData(){
  const raw=localStorage.getItem(STORAGE_KEY); if(!raw) return;
  try{
    const d=JSON.parse(raw);
    patiënten=d.patiënten||[]; recepten=d.recepten||[]; wachttijden=d.wachttijden||[]; laatsteKlik=d.laatsteKlik||null; laatsteNaam=d.laatsteNaam||"-";
    auditLog=d.auditLog||[]; doctorAvailability=d.doctorAvailability||{}; personRooms=d.personRooms||{};
    afspraken=d.afspraken||[]; sollicitaties=d.sollicitaties||[]; reportsByPerson=d.reportsByPerson||{};
    if(d.rooms){ rooms1=d.rooms.rooms1||rooms1; rooms2=d.rooms.rooms2||rooms2; }
    rolesByRoep=d.rolesByRoep||rolesByRoep; namesByRoep=d.namesByRoep||namesByRoep; activeUsers=d.activeUsers||activeUsers; eveningRoles=d.eveningRoles||eveningRoles;
  }catch(e){ console.warn("Kon data niet laden:", e); }
}
function resetAll(){
  if(!confirm("Weet je zeker dat je ALLE data wilt wissen?")) return;
  localStorage.removeItem(STORAGE_KEY);
  localStorage.removeItem("zz_roles_v2");
  localStorage.removeItem("zz_names_v1");
  localStorage.removeItem("zz_evening_roles_v1");
  localStorage.removeItem("zz_active_users_v1");
  localStorage.removeItem(BUSY_KEY);
  location.reload();
}

/* ===========================
   UTIL
=========================== */
function now(){ return Date.now(); }
function toSeconds(ms){ return Math.round(ms/1000); }
function minutesSince(ts){ return (now() - (ts || now()))/60000; }
function fmtDate(ts){ const d=new Date(ts); return d.toLocaleString(); }
function fmtDateDay(ts){ const d=new Date(ts); return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0"); }
function triClass(tri){
  const t=(tri||"").toLowerCase();
  if(t==="rood") return "tri-red"; if(t==="oranje") return "tri-orange"; if(t==="geel") return "tri-yellow"; if(t==="groen") return "tri-green"; return "tri-blue";
}
function triWeight(tri){ return { "rood":0,"oranje":1,"geel":2,"groen":3,"blauw":4 }[(tri||"").toLowerCase()] ?? 3; }
function ensureWachtStart(p){ if(p.status==="Wachtkamer" && !p.wachtStart) p.wachtStart=now(); if(p.status!=="Wachtkamer") p.wachtStart=null; }
function logAction(actor, action, meta){ auditLog.push({ts:now(), actor, action, meta}); saveData(); }
function personKeyFromPatient(p){ return p.id || ("NAME:"+ (p.naam||"").toLowerCase().trim()); }
function pushReportEvent(p, type, details){
  const key=personKeyFromPatient(p);
  if(!reportsByPerson[key]) reportsByPerson[key]=[];
  reportsByPerson[key].push({ ts:now(), type, details });
  saveData();
}

/* ===========================
   AFSPRAKEN (PUBLIEK)
=========================== */
function appointmentSuggestDept(text){
  const t=(text||"").toLowerCase();
  const pairs = [
    {k:["ongeval","bloeding","breuk","bewusteloos","flauw","acute","val"], dept:"SEH"},
    {k:["pijn op de borst","hartklopp","benauwd","kortademig","hart","cardio"], dept:"Cardiologie"},
    {k:["adem","hoest","long","astma","copd"], dept:"Longgeneeskunde"},
    {k:["hoofdpijn","insult","verlamming","uitval","migraine"], dept:"Neurologie"},
    {k:["snijwond","hechten","operatie","chirurg","wond"], dept:"Chirurgie"},
    {k:["recept","medicijn","medicatie","herhaal"], dept:"Apotheek"},
    {k:["huisarts","verkouden","keelpijn","oorpijn","lichte koorts"], dept:"Huisartsenpost"},
    {k:["afspraak","administr","verzekering","balie"], dept:"Administratie"}
  ];
  for(const p of pairs){ if(p.k.some(k=>t.includes(k))) return p.dept; }
  return "Huisartsenpost";
}
function afspraakLeeg(){
  ["ap_roblox","ap_discord","ap_dt","ap_reden","ap_afdeling","ap_suggest","ap_pid"].forEach(id=>{ const el=document.getElementById(id); if(el) el.value=""; });
  document.getElementById("ap_msg").textContent="";
}
function detectAfdeling(){
  const reden=document.getElementById("ap_reden").value.trim();
  if(!reden){ document.getElementById("ap_msg").textContent="Vul eerst de reden in."; return; }
  const dept=appointmentSuggestDept(reden);
  document.getElementById("ap_suggest").value=dept;
  if(!document.getElementById("ap_afdeling").value) document.getElementById("ap_afdeling").value=dept;
}
function afspraakOpslaan(){
